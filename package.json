{
  "name": "heritage-foundry",
  "version": "1.0.0",
  "description": "AI非遗文创与手作方案生成平台",
  "engines": {
    "node": ">=22.21.0"
  },
  "scripts": {
    "check:node": "node scripts/check-node-runtime.js",
    "predev": "npm run check:node",
    "dev": "concurrently --kill-others-on-fail --names WEB,API \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "vite",
    "predev:api": "npm run check:node",
    "dev:api": "node --use-env-proxy server.js",
    "build": "vite build",
    "preview": "vite preview",
    "server": "npm run dev:api",
    "test": "vitest --root . run",
    "start": "npm run dev",
    "vercel-build": "npm run build"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@supabase/supabase-js": "^2.110.0",
    "@tweenjs/tween.js": "^20.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide": "^0.300.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "concurrently": "^10.0.3",
    "draco3dgltf": "^1.5.7",
    "sharp": "^0.35.3",
    "supertest": "^7.2.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
